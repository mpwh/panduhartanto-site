---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import yaml from 'js-yaml';

const contentPath = resolve(process.cwd(), 'CONTENT.yaml');
const content = yaml.load(readFileSync(contentPath, 'utf8'));
const { identity, now, highlights, social, experience, education } = content;

const iconMap = {
  linkedin: `<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  twitter: `<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  github: `<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  link: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
};

const typeBadge = {
  research: 'Research',
  thought: 'Note',
  project: 'Project',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{identity.name}</title>
  <meta name="description" content={identity.tagline} />
  <meta property="og:title" content={identity.name} />
  <meta property="og:description" content={identity.tagline} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://panduhartanto.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; }
    html { font-size: 16px; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #fafaf9;
      color: #1c1917;
      line-height: 1.6;
      margin: 0;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      max-width: 640px;
      margin: 0 auto;
      padding: 80px 24px 120px;
    }

    /* ── Header ── */
    header { margin-bottom: 72px; }
    h1 {
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: #0c0a09;
      margin: 0 0 6px;
    }
    .tagline {
      font-size: 1rem;
      font-weight: 400;
      color: #44403c;
      margin: 0 0 24px;
    }
    .bio {
      font-size: 0.9375rem;
      color: #57534e;
      line-height: 1.75;
      margin: 0;
      white-space: pre-line;
    }

    /* ── Section ── */
    section { margin-bottom: 64px; }
    .section-label {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #78716c;
      margin: 0 0 28px;
      padding-bottom: 12px;
      border-bottom: 1px solid #e7e5e4;
    }
    .updated {
      font-size: 0.75rem;
      color: #a8a29e;
      margin: -20px 0 24px;
    }

    /* ── Now items ── */
    .now-list { display: flex; flex-direction: column; gap: 28px; }
    .now-item {}
    .now-title {
      font-size: 0.9375rem;
      font-weight: 500;
      color: #1c1917;
      margin: 0 0 4px;
      display: flex;
      align-items: baseline;
      gap: 6px;
      flex-wrap: wrap;
    }
    .now-title .sep { color: #d6d3d1; }
    .now-title a {
      color: #1c1917;
      text-decoration: none;
      border-bottom: 1px solid #d6d3d1;
      transition: border-color 0.15s;
    }
    .now-title a:hover { border-color: #78716c; }
    .now-desc {
      font-size: 0.875rem;
      color: #78716c;
      line-height: 1.7;
      margin: 0;
    }

    /* ── Highlights ── */
    .highlight-list { display: flex; flex-direction: column; gap: 24px; }
    .highlight-item {
      padding: 20px;
      background: #fff;
      border: 1px solid #e7e5e4;
      border-radius: 8px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .highlight-item:hover {
      border-color: #a8a29e;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .highlight-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .badge {
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #78716c;
      background: #f5f5f4;
      padding: 2px 8px;
      border-radius: 4px;
    }
    .highlight-date {
      font-size: 0.75rem;
      color: #a8a29e;
    }
    .highlight-title {
      font-size: 0.9375rem;
      font-weight: 500;
      color: #1c1917;
      margin: 0 0 6px;
    }
    .highlight-title a {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px solid #d6d3d1;
    }
    .highlight-title a:hover { border-color: #78716c; }
    .highlight-desc {
      font-size: 0.875rem;
      color: #78716c;
      line-height: 1.65;
      margin: 0;
    }

    /* ── Social ── */
    .social-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 0.875rem;
      font-weight: 500;
      color: #44403c;
      text-decoration: none;
      border: 1px solid #d6d3d1;
      border-radius: 6px;
      padding: 8px 14px;
      transition: all 0.15s;
      background: #fff;
    }
    .social-link:hover {
      color: #0c0a09;
      border-color: #78716c;
      background: #fafaf9;
    }
    .social-link svg { flex-shrink: 0; color: #a8a29e; }
    .social-link:hover svg { color: #57534e; }

    /* ── Experience ── */
    .exp-list { display: flex; flex-direction: column; gap: 24px; }
    .exp-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: start;
    }
    .exp-title {
      font-size: 0.9375rem;
      font-weight: 500;
      color: #1c1917;
      margin: 0 0 2px;
    }
    .exp-org {
      font-size: 0.875rem;
      color: #57534e;
      margin: 0 0 4px;
    }
    .exp-desc {
      font-size: 0.8125rem;
      color: #78716c;
      line-height: 1.65;
      margin: 0;
    }
    .exp-period {
      font-size: 0.75rem;
      color: #a8a29e;
      white-space: nowrap;
      padding-top: 2px;
    }

    /* ── Education ── */
    .edu-divider {
      border: none;
      border-top: 1px solid #e7e5e4;
      margin: 28px 0;
    }
    .edu-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
    }
    .edu-degree {
      font-size: 0.9375rem;
      font-weight: 500;
      color: #1c1917;
      margin: 0 0 2px;
    }
    .edu-inst {
      font-size: 0.875rem;
      color: #78716c;
      margin: 0;
    }

    /* ── Footer ── */
    footer {
      padding-top: 48px;
      border-top: 1px solid #e7e5e4;
    }
    .footer-text {
      font-size: 0.75rem;
      color: #a8a29e;
      margin: 0;
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- ── 0. IDENTITY ── -->
    <header>
      <h1>{identity.name}</h1>
      <p class="tagline">{identity.tagline}</p>
      <p class="bio">{identity.bio}</p>
    </header>

    <!-- ── 1. NOW ── -->
    <section>
      <p class="section-label">Now</p>
      <p class="updated">Updated {now.updated}</p>
      <div class="now-list">
        {now.items.map((item) => (
          <div class="now-item">
            <p class="now-title">
              <span>{item.role}</span>
              <span class="sep">·</span>
              {item.url
                ? <a href={item.url} target="_blank" rel="noopener noreferrer">{item.org}</a>
                : <span style="color:#44403c">{item.org}</span>
              }
            </p>
            <p class="now-desc">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 1a. HIGHLIGHTS ── -->
    {highlights && highlights.length > 0 && (
      <section>
        <p class="section-label">Writing & Notes</p>
        <div class="highlight-list">
          {highlights.map((item) => (
            <div class="highlight-item">
              <div class="highlight-meta">
                <span class="badge">{typeBadge[item.type] || item.type}</span>
                <span class="highlight-date">{item.date}</span>
              </div>
              <p class="highlight-title">
                {item.url
                  ? <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                  : item.title
                }
              </p>
              <p class="highlight-desc">{item.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── 2. FIND ME ── -->
    <section>
      <p class="section-label">Find me</p>
      <div class="social-list">
        {social.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <span set:html={iconMap[item.icon] || iconMap.link} />
            {item.label}
          </a>
        ))}
      </div>
    </section>

    <!-- ── 3. BACKGROUND ── -->
    <section>
      <p class="section-label">Background</p>
      <div class="exp-list">
        {experience.map((job) => (
          <div class="exp-item">
            <div>
              <p class="exp-title">{job.title}</p>
              <p class="exp-org">{job.org}</p>
              <p class="exp-desc">{job.description}</p>
            </div>
            <p class="exp-period">{job.period}</p>
          </div>
        ))}
      </div>

      {education && education.length > 0 && (
        <>
          <hr class="edu-divider" />
          {education.map((edu) => (
            <div class="edu-item">
              <div>
                <p class="edu-degree">{edu.degree}</p>
                <p class="edu-inst">{edu.institution}</p>
              </div>
              {edu.period && <p class="exp-period">{edu.period}</p>}
            </div>
          ))}
        </>
      )}
    </section>

    <!-- Footer -->
    <footer>
      <p class="footer-text">Jakarta, Indonesia · {new Date().getFullYear()}</p>
    </footer>

  </div>
</body>
</html>
