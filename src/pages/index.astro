---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import yaml from 'js-yaml';

const contentPath = resolve(process.cwd(), 'CONTENT.yaml');
const content = yaml.load(readFileSync(contentPath, 'utf8'));
const { identity, now, highlights, social, experience, education } = content;

const iconMap = {
  linkedin: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  twitter: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  github: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  link: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
};

const typeBadge = {
  research: { label: 'Research', class: 'bg-stone-100 text-stone-600' },
  thought: { label: 'Thought', class: 'bg-stone-100 text-stone-600' },
  project: { label: 'Project', class: 'bg-stone-100 text-stone-600' },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{identity.name}</title>
  <meta name="description" content={identity.tagline} />
  <meta property="og:title" content={identity.name} />
  <meta property="og:description" content={identity.tagline} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://panduhartanto.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-white text-stone-900 font-sans antialiased">

  <!-- Layout wrapper -->
  <div class="max-w-2xl mx-auto px-6 py-20">

    <!-- ── 0. IDENTITY ── -->
    <header class="mb-20">
      <h1 class="text-2xl font-semibold tracking-tight mb-2">{identity.name}</h1>
      <p class="text-stone-500 text-base mb-6">{identity.tagline}</p>
      <p class="text-stone-700 text-base leading-relaxed whitespace-pre-line">{identity.bio}</p>
    </header>

    <!-- ── 1. NOW ── -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-6">Now</h2>
      <p class="text-xs text-stone-400 mb-5">Updated {now.updated}</p>
      <div class="space-y-6">
        {now.items.map((item) => (
          <div>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="font-medium text-stone-900">{item.role}</span>
              <span class="text-stone-400">·</span>
              {item.url ? (
                <a href={item.url} class="text-stone-600 hover:text-stone-900 transition-colors">{item.org}</a>
              ) : (
                <span class="text-stone-600">{item.org}</span>
              )}
            </div>
            <p class="text-stone-500 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 1a. HIGHLIGHTS ── -->
    {highlights && highlights.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-6">Writing & Notes</h2>
        <div class="space-y-5">
          {highlights.map((item) => {
            const badge = typeBadge[item.type] || typeBadge.thought;
            return (
              <div class="group">
                <div class="flex items-start gap-3">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      {item.url ? (
                        <a href={item.url} class="font-medium text-stone-900 hover:text-stone-600 transition-colors text-sm">{item.title}</a>
                      ) : (
                        <span class="font-medium text-stone-900 text-sm">{item.title}</span>
                      )}
                      <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${badge.class}`}>{badge.label}</span>
                    </div>
                    <p class="text-stone-500 text-sm leading-relaxed">{item.description}</p>
                    <p class="text-stone-400 text-xs mt-1">{item.date}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- ── 2. FIND ME ONLINE ── -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-6">Find me</h2>
      <div class="flex flex-wrap gap-3">
        {social.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-stone-600 hover:text-stone-900 border border-stone-200 hover:border-stone-400 rounded-lg px-3 py-2 transition-all"
          >
            <span set:html={iconMap[item.icon] || iconMap.link} />
            {item.label}
          </a>
        ))}
      </div>
    </section>

    <!-- ── 3. BACKGROUND ── -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-6">Background</h2>
      <div class="space-y-6">
        {experience.map((job) => (
          <div class="flex gap-4">
            <div class="flex-1">
              <div class="flex items-baseline gap-2 mb-1 flex-wrap">
                <span class="font-medium text-stone-900 text-sm">{job.title}</span>
                <span class="text-stone-400 text-sm">·</span>
                <span class="text-stone-600 text-sm">{job.org}</span>
              </div>
              <p class="text-stone-500 text-sm leading-relaxed">{job.description}</p>
            </div>
            <div class="text-right shrink-0">
              <span class="text-stone-400 text-xs whitespace-nowrap">{job.period}</span>
            </div>
          </div>
        ))}
      </div>

      {education && education.length > 0 && (
        <div class="mt-8 pt-8 border-t border-stone-100 space-y-4">
          {education.map((edu) => (
            <div class="flex gap-4">
              <div class="flex-1">
                <div class="flex items-baseline gap-2 mb-1 flex-wrap">
                  <span class="font-medium text-stone-900 text-sm">{edu.degree}</span>
                  <span class="text-stone-400 text-sm">·</span>
                  <span class="text-stone-600 text-sm">{edu.institution}</span>
                </div>
                {edu.note && <p class="text-stone-400 text-xs italic">{edu.note}</p>}
              </div>
              {edu.period && (
                <div class="text-right shrink-0">
                  <span class="text-stone-400 text-xs">{edu.period}</span>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- Footer -->
    <footer class="pt-8 border-t border-stone-100">
      <p class="text-stone-400 text-xs">
        Jakarta, Indonesia · {new Date().getFullYear()}
      </p>
    </footer>

  </div>

</body>
</html>
